  created_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  cart_item_modifiers          cart_item_modifiers[]
  catalog_item_modifier_groups catalog_item_modifier_groups[]
  stores                       stores                         @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modifier_options             modifier_options[]
}

model modifier_options {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  modifier_group_id   String                @db.Uuid
  name                String                @db.VarChar(120)
  price_delta_amount  Decimal               @default(0) @db.Decimal(10, 2)
  is_default          Boolean               @default(false)
  is_active           Boolean               @default(true)
  sort_order          Int                   @default(0)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  cart_item_modifiers cart_item_modifiers[]
  modifier_groups     modifier_groups       @relation(fields: [modifier_group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
