model order_status_history {
  id                 String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id           String                    @db.Uuid
  old_status         order_status_type?
  new_status         order_status_type
  changed_by_user_id String?                   @db.Uuid
  source             status_change_source_type
  notes              String?
  created_at         DateTime                  @default(now()) @db.Timestamptz(6)
  users              users?                    @relation(fields: [changed_by_user_id], references: [id], onUpdate: NoAction)
  orders             orders                    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_order_status_history_created")
  @@index([order_id], map: "idx_order_status_history_order")
}

model orders {
  id                                   String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_code                           String                       @unique @db.VarChar(30)
  customer_user_id                     String                       @db.Uuid
  store_id                             String                       @db.Uuid
  branch_id                            String                       @db.Uuid
  rider_user_id                        String?                      @db.Uuid
  delivery_address_id                  String                       @db.Uuid
  source_channel                       source_channel_type
  order_type                           order_type_enum
  business_category_snapshot           String                       @db.VarChar(50)
  status                               order_status_type
  payment_status                       payment_status_type
  fulfillment_status                   fulfillment_status_type
  subtotal_amount                      Decimal                      @db.Decimal(10, 2)
  modifier_total_amount                Decimal                      @default(0) @db.Decimal(10, 2)
