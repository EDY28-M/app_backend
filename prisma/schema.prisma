generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model addresses {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String?             @db.Uuid
  label             String?             @db.VarChar(80)
  contact_name      String?             @db.VarChar(120)
  contact_phone     String?             @db.VarChar(20)
  country_code      String              @default("PE") @db.VarChar(5)
  region            String              @db.VarChar(120)
  province          String              @db.VarChar(120)
  district          String              @db.VarChar(120)
  city              String              @db.VarChar(120)
  address_line1     String              @db.VarChar(255)
  address_line2     String?             @db.VarChar(255)
  reference         String?
  latitude          Decimal             @db.Decimal(10, 7)
  longitude         Decimal             @db.Decimal(10, 7)
  is_default        Boolean             @default(false)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  users             users?              @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  customer_profiles customer_profiles[]
  deliveries        deliveries[]
  orders            orders[]
  store_branches    store_branches[]

  @@index([latitude, longitude], map: "idx_addresses_coords")
}

model branch_catalog_items {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branch_id             String                  @db.Uuid
  catalog_item_id       String                  @db.Uuid
  variant_id            String?                 @db.Uuid
  price_amount          Decimal                 @db.Decimal(10, 2)
  compare_at_amount     Decimal?                @db.Decimal(10, 2)
  stock_qty             Int?
  reserved_qty          Int                     @default(0)
  is_available          Boolean                 @default(true)
  availability_mode     availability_mode_type
  prep_time_minutes     Int?
  sort_order            Int                     @default(0)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  store_branches        store_branches          @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  catalog_items         catalog_items           @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  catalog_item_variants catalog_item_variants?  @relation(fields: [variant_id], references: [id], onUpdate: NoAction)
  branch_item_schedules branch_item_schedules[]
  cart_items            cart_items[]
  order_items           order_items[]

  @@index([branch_id], map: "idx_branch_catalog_branch")
  @@index([catalog_item_id], map: "idx_branch_catalog_item")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model branch_item_schedules {
  id                     String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branch_catalog_item_id String               @db.Uuid
  day_of_week            Int                  @db.SmallInt
  start_time             DateTime             @db.Time(6)
  end_time               DateTime             @db.Time(6)
  is_active              Boolean              @default(true)
  created_at             DateTime             @default(now()) @db.Timestamptz(6)
  branch_catalog_items   branch_catalog_items @relation(fields: [branch_catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model branch_operating_hours {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branch_id      String         @db.Uuid
  day_of_week    Int            @db.SmallInt
  open_time      DateTime?      @db.Time(6)
  close_time     DateTime?      @db.Time(6)
  is_closed      Boolean        @default(false)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  store_branches store_branches @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([branch_id, day_of_week])
}

model business_categories {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  stores     stores[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_item_modifiers {
  id                 String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cart_item_id       String           @db.Uuid
  modifier_group_id  String           @db.Uuid
  modifier_option_id String           @db.Uuid
  qty                Int              @default(1)
  price_delta_amount Decimal          @default(0) @db.Decimal(10, 2)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  cart_items         cart_items       @relation(fields: [cart_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modifier_groups    modifier_groups  @relation(fields: [modifier_group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modifier_options   modifier_options @relation(fields: [modifier_option_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id                     String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cart_id                String                 @db.Uuid
  catalog_item_id        String                 @db.Uuid
  variant_id             String?                @db.Uuid
  branch_catalog_item_id String                 @db.Uuid
  qty                    Int
  unit_price_amount      Decimal                @db.Decimal(10, 2)
  notes                  String?
  created_at             DateTime               @default(now()) @db.Timestamptz(6)
  updated_at             DateTime               @default(now()) @db.Timestamptz(6)
  cart_item_modifiers    cart_item_modifiers[]
  branch_catalog_items   branch_catalog_items   @relation(fields: [branch_catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  carts                  carts                  @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  catalog_items          catalog_items          @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  catalog_item_variants  catalog_item_variants? @relation(fields: [variant_id], references: [id], onUpdate: NoAction)
}

model carts {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_user_id String           @db.Uuid
  store_id         String           @db.Uuid
  branch_id        String           @db.Uuid
  status           cart_status_type @default(active)
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @default(now()) @db.Timestamptz(6)
  cart_items       cart_items[]
  store_branches   store_branches   @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users            @relation(fields: [customer_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stores           stores           @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_user_id], map: "idx_carts_customer")
  @@index([store_id, branch_id], map: "idx_carts_store_branch")
}

model catalog_categories {
  id                       String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  store_id                 String               @db.Uuid
  parent_id                String?              @db.Uuid
  name                     String               @db.VarChar(120)
  slug                     String               @db.VarChar(140)
  sort_order               Int                  @default(0)
  is_active                Boolean              @default(true)
  created_at               DateTime             @default(now()) @db.Timestamptz(6)
  catalog_categories       catalog_categories?  @relation("catalog_categoriesTocatalog_categories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_catalog_categories catalog_categories[] @relation("catalog_categoriesTocatalog_categories")
  stores                   stores               @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  catalog_items            catalog_items[]

  @@unique([store_id, slug])
  @@index([store_id], map: "idx_catalog_categories_store")
}

model catalog_item_modifier_groups {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  catalog_item_id   String          @db.Uuid
  modifier_group_id String          @db.Uuid
  sort_order        Int             @default(0)
  catalog_items     catalog_items   @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modifier_groups   modifier_groups @relation(fields: [modifier_group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([catalog_item_id, modifier_group_id])
}

model catalog_item_variants {
  id                    String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  catalog_item_id       String                 @db.Uuid
  name                  String                 @db.VarChar(150)
  sku                   String?                @db.VarChar(80)
  barcode               String?                @db.VarChar(80)
  price_modifier_amount Decimal                @default(0) @db.Decimal(10, 2)
  is_default            Boolean                @default(false)
  is_active             Boolean                @default(true)
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime               @default(now()) @db.Timestamptz(6)
  branch_catalog_items  branch_catalog_items[]
  cart_items            cart_items[]
  catalog_items         catalog_items          @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items           order_items[]
}

model catalog_items {
  id                                                           String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  store_id                                                     String                         @db.Uuid
  category_id                                                  String?                        @db.Uuid
  item_type                                                    item_type_enum
  name                                                         String                         @db.VarChar(180)
  slug                                                         String                         @db.VarChar(200)
  description                                                  String?
  image_url                                                    String?
  sku                                                          String?                        @db.VarChar(80)
  barcode                                                      String?                        @db.VarChar(80)
  brand                                                        String?                        @db.VarChar(120)
  unit_label                                                   String?                        @db.VarChar(30)
  base_price_amount                                            Decimal                        @db.Decimal(10, 2)
  is_on_offer                                                  Boolean                        @default(false)
  offer_price_amount                                           Decimal?                       @db.Decimal(10, 2)
  requires_age_verification                                    Boolean                        @default(false)
  allows_notes                                                 Boolean                        @default(true)
  is_active                                                    Boolean                        @default(true)
  created_at                                                   DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at                                                   DateTime                       @default(now()) @db.Timestamptz(6)
  branch_catalog_items                                         branch_catalog_items[]
  cart_items                                                   cart_items[]
  catalog_item_modifier_groups                                 catalog_item_modifier_groups[]
  catalog_item_variants                                        catalog_item_variants[]
  catalog_categories                                           catalog_categories?            @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  stores                                                       stores                         @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  combo_items_combo_items_child_catalog_item_idTocatalog_items combo_items[]                  @relation("combo_items_child_catalog_item_idTocatalog_items")
  combo_items_combo_items_combo_catalog_item_idTocatalog_items combo_items[]                  @relation("combo_items_combo_catalog_item_idTocatalog_items")
  order_items                                                  order_items[]

  @@unique([store_id, slug])
  @@index([store_id, slug], map: "idx_catalog_items_slug")
  @@index([store_id], map: "idx_catalog_items_store")
  @@index([item_type], map: "idx_catalog_items_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model combo_items {
  id                                                             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  combo_catalog_item_id                                          String        @db.Uuid
  child_catalog_item_id                                          String        @db.Uuid
  default_qty                                                    Int           @default(1)
  is_required                                                    Boolean       @default(true)
  sort_order                                                     Int           @default(0)
  created_at                                                     DateTime      @default(now()) @db.Timestamptz(6)
  catalog_items_combo_items_child_catalog_item_idTocatalog_items catalog_items @relation("combo_items_child_catalog_item_idTocatalog_items", fields: [child_catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  catalog_items_combo_items_combo_catalog_item_idTocatalog_items catalog_items @relation("combo_items_combo_catalog_item_idTocatalog_items", fields: [combo_catalog_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model customer_profiles {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String     @unique @db.Uuid
  default_address_id String?    @db.Uuid
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  updated_at         DateTime   @default(now()) @db.Timestamptz(6)
  addresses          addresses? @relation(fields: [default_address_id], references: [id], onUpdate: NoAction)
  users              users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model customer_favorites {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  store_id   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stores     stores   @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, store_id])
  @@index([user_id], map: "idx_customer_favorites_user")
}

model deliveries {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id           String               @unique @db.Uuid
  rider_profile_id   String?              @db.Uuid
  pickup_branch_id   String               @db.Uuid
  dropoff_address_id String               @db.Uuid
  status             delivery_status_type
  distance_km        Decimal?             @db.Decimal(8, 2)
  estimated_minutes  Int?
  assigned_at        DateTime?            @db.Timestamptz(6)
  picked_up_at       DateTime?            @db.Timestamptz(6)
  delivered_at       DateTime?            @db.Timestamptz(6)
  failed_at          DateTime?            @db.Timestamptz(6)
  failure_reason     String?
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  addresses          addresses            @relation(fields: [dropoff_address_id], references: [id], onUpdate: NoAction)
  orders             orders               @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  store_branches     store_branches       @relation(fields: [pickup_branch_id], references: [id], onUpdate: NoAction)
  rider_profiles     rider_profiles?      @relation(fields: [rider_profile_id], references: [id], onUpdate: NoAction)

  @@index([status], map: "idx_deliveries_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model delivery_zones {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branch_id         String         @db.Uuid
  name              String         @db.VarChar(120)
  zone_type         zone_type_enum
  center_lat        Decimal?       @db.Decimal(10, 7)
  center_lng        Decimal?       @db.Decimal(10, 7)
  radius_meters     Int?
  polygon_geojson   Json?
  base_fee_amount   Decimal        @db.Decimal(10, 2)
  per_km_fee_amount Decimal        @default(0) @db.Decimal(10, 2)
  min_eta_minutes   Int
  max_eta_minutes   Int
  is_active         Boolean        @default(true)
  priority          Int            @default(1)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  store_branches    store_branches @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([branch_id], map: "idx_delivery_zones_branch")
}

model merchant_profiles {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  owner_user_id        String                 @db.Uuid
  business_name        String                 @db.VarChar(150)
  legal_name           String?                @db.VarChar(180)
  tax_id               String?                @db.VarChar(30)
  billing_email        String?                @db.VarChar(150)
  phone_e164           String?                @db.VarChar(20)
  logo_url             String?
  status               merchant_status_type   @default(onboarding)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  users                users                  @relation(fields: [owner_user_id], references: [id], onUpdate: NoAction)
  merchant_settlements merchant_settlements[]
  merchant_users       merchant_users[]
  stores               stores[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model merchant_settlements {
  id                     String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  merchant_id            String                 @db.Uuid
  period_start           DateTime               @db.Date
  period_end             DateTime               @db.Date
  gross_sales_amount     Decimal                @db.Decimal(12, 2)
  commission_amount      Decimal                @db.Decimal(12, 2)
  delivery_fee_collected Decimal                @default(0) @db.Decimal(12, 2)
  service_fee_collected  Decimal                @default(0) @db.Decimal(12, 2)
  adjustments_amount     Decimal                @default(0) @db.Decimal(12, 2)
  net_payable_amount     Decimal                @db.Decimal(12, 2)
