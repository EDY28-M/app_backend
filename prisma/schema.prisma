  paid_at                DateTime?              @db.Timestamptz(6)
  merchant_profiles      merchant_profiles      @relation(fields: [merchant_id], references: [id], onUpdate: NoAction)

  @@index([merchant_id], map: "idx_merchant_settlements_merchant")
  @@index([period_start, period_end], map: "idx_merchant_settlements_period")
}

model merchant_users {
  id                String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  merchant_id       String                  @db.Uuid
  user_id           String                  @db.Uuid
  role_code         merchant_user_role_type
  status            String                  @default("active") @db.VarChar(20)
  created_at        DateTime                @default(now()) @db.Timestamptz(6)
  merchant_profiles merchant_profiles       @relation(fields: [merchant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([merchant_id, user_id])
}

model modifier_groups {
