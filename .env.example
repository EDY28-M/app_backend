# =============================================================================
# Variables de entorno - APP Marketplace Backend
# Plataforma: Android (Flutter)
# Copia este archivo como .env y rellena los valores
# =============================================================================

# --- Base de datos ---
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/applicationfood?schema=public"

# --- JWT ---
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRET_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CAMBIA_ESTO_POR_OTRO_SECRET_DIFERENTE"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Google Sign-In (Android) ---
# IMPORTANTE: Usa el "Web Client ID" de Google Cloud Console (NO el Android Client ID).
# El Android Client ID se configura en el google-services.json del proyecto Flutter.
# El Web Client ID se usa aquí para verificar el id_token server-side.
#
# Pasos:
# 1. Ve a console.cloud.google.com > APIs y servicios > Credenciales
# 2. Crea un "ID de cliente OAuth" tipo "Aplicación web"
# 3. Copia el Client ID aquí
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- OTP / SMS ---
# Modos: "local" (dev, muestra OTP en logs), "twilio" (produccion, envia SMS real)
OTP_PROVIDER="local"
OTP_EXPIRY_MINUTES=5
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Server ---
PORT=3000
NODE_ENV="development"
